{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]", "notIn": ["string"] },
    { "open": "[[", "close": "]]", "notIn": ["string"] },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'",  "close": "'",  "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "'",  "close": "'"  }
  ],
  "wordPattern": "[a-zA-Z_][\\w\\-]*"
}
