{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Fly Manifest (fly.toml)",
  "scopeName": "source.flyp-toml",
  "patterns": [
    { "include": "#comment" },
    { "include": "#array-table-header" },
    { "include": "#table-header" },
    { "include": "#keyval" }
  ],
  "repository": {

    "comment": {
      "name": "comment.line.number-sign.flyp-toml",
      "match": "\\s*#.*$"
    },

    "array-table-header": {
      "comment": "[[bin]], [[lib]], [[test]] — array-of-tables header",
      "match": "^\\s*(\\[\\[)\\s*([a-zA-Z_][\\w\\-.]*?)\\s*(\\]\\])",
      "captures": {
        "1": { "name": "punctuation.definition.table.array.begin.flyp-toml" },
        "2": { "name": "entity.name.section.array.flyp-toml" },
        "3": { "name": "punctuation.definition.table.array.end.flyp-toml" }
      }
    },

    "table-header": {
      "comment": "[package], [dependencies], [profile.debug] etc.",
      "match": "^\\s*(\\[)\\s*([a-zA-Z_][\\w\\-.]*?)\\s*(\\])",
      "captures": {
        "1": { "name": "punctuation.definition.table.begin.flyp-toml" },
        "2": { "name": "entity.name.section.flyp-toml" },
        "3": { "name": "punctuation.definition.table.end.flyp-toml" }
      }
    },

    "keyval": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#key-equals" },
        { "include": "#val" }
      ]
    },

    "key-equals": {
      "comment": "Key name followed by = on a line (top-level keys)",
      "match": "^\\s*([a-zA-Z_][\\w\\-]*)\\s*(=)",
      "captures": {
        "1": { "name": "support.type.property-name.flyp-toml" },
        "2": { "name": "punctuation.separator.key-value.flyp-toml" }
      }
    },

    "val": {
      "patterns": [
        { "include": "#string-basic" },
        { "include": "#string-literal" },
        { "include": "#inline-table" },
        { "include": "#array-val" },
        { "include": "#boolean" },
        { "include": "#integer" }
      ]
    },

    "string-basic": {
      "name": "string.quoted.double.flyp-toml",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.flyp-toml",
          "match": "\\\\[btnfr\"\\\\]" },
        { "name": "constant.character.escape.unicode.flyp-toml",
          "match": "\\\\u[0-9a-fA-F]{4}" },
        { "name": "constant.character.escape.unicode.long.flyp-toml",
          "match": "\\\\U[0-9a-fA-F]{8}" }
      ]
    },

    "string-literal": {
      "name": "string.quoted.single.flyp-toml",
      "begin": "'",
      "end": "'"
    },

    "boolean": {
      "name": "constant.language.boolean.flyp-toml",
      "match": "\\b(true|false)\\b"
    },

    "integer": {
      "name": "constant.numeric.integer.flyp-toml",
      "match": "(?<![\\w\\-])[-+]?(?:0|[1-9][0-9]*)(?![\\w\\.])"
    },

    "inline-table": {
      "name": "meta.structure.table.inline.flyp-toml",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.table.inline.begin.flyp-toml" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.table.inline.end.flyp-toml" } },
      "patterns": [
        { "include": "#comment" },
        { "include": "#inline-keyval" },
        { "name": "punctuation.separator.inline-table.flyp-toml", "match": "," }
      ]
    },

    "inline-keyval": {
      "comment": "key = value pairs inside { }",
      "patterns": [
        {
          "comment": "key = \"string value\"",
          "match": "([a-zA-Z_][\\w\\-]*)\\s*(=)\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "support.type.property-name.inline.flyp-toml" },
            "2": { "name": "punctuation.separator.key-value.flyp-toml" },
            "3": { "name": "string.quoted.double.flyp-toml" }
          }
        },
        {
          "comment": "key = bare (boolean / integer)",
          "match": "([a-zA-Z_][\\w\\-]*)\\s*(=)\\s*(true|false|[-+]?[0-9]+)",
          "captures": {
            "1": { "name": "support.type.property-name.inline.flyp-toml" },
            "2": { "name": "punctuation.separator.key-value.flyp-toml" },
            "3": { "name": "constant.language.flyp-toml" }
          }
        }
      ]
    },

    "array-val": {
      "name": "meta.structure.array.flyp-toml",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.definition.array.begin.flyp-toml" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.array.end.flyp-toml" } },
      "patterns": [
        { "include": "#comment" },
        { "include": "#string-basic" },
        { "include": "#string-literal" },
        { "include": "#boolean" },
        { "include": "#integer" },
        { "name": "punctuation.separator.array.flyp-toml", "match": "," }
      ]
    }
  }
}
