{
  "name": "fly-vscode-extension",
  "displayName": "Fly Programming Language",
  "description": "Fly programming language support for Visual Studio Code: syntax highlighting, snippets, and language configuration for .fly files.",
  "version": "0.3.1",
  "publisher": "fly-lang",
  "icon": "fly_logo.png",
  "license": "Apache-2.0",
  "homepage": "https://flylang.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/fly-lang/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/fly-lang/vscode-extension/issues"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "fly",
    "flylang",
    "fly-lang"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "flyp-toml",
        "aliases": ["Fly Manifest", "flyp-toml"],
        "filenames": ["fly.toml"],
        "configuration": "./flyp-toml-language-configuration.json"
      },
      {
        "id": "fly",
        "aliases": [
          "Fly",
          "fly"
        ],
        "extensions": [
          ".fly",
          ".fly.h"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/fly-light.svg",
          "dark": "./icons/fly-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "flyp-toml",
        "scopeName": "source.flyp-toml",
        "path": "./syntaxes/flyp-toml.tmLanguage.json"
      },
      {
        "language": "fly",
        "scopeName": "source.fly",
        "path": "./syntaxes/fly.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "fly.selectCompiler",
        "title": "Fly: Select Compiler",
        "category": "Fly"
      },
      {
        "command": "fly.buildFile",
        "title": "Fly: Build File",
        "category": "Fly",
        "icon": "$(play)"
      },
      {
        "command": "fly.runFile",
        "title": "Fly: Run File",
        "category": "Fly",
        "icon": "$(run)"
      },
      {
        "command": "fly.flypBuild",
        "title": "Flyp: Build",
        "category": "Fly",
        "icon": "$(play)"
      },
      {
        "command": "fly.flypRun",
        "title": "Flyp: Run",
        "category": "Fly",
        "icon": "$(run-above)"
      },
      {
        "command": "fly.flypTest",
        "title": "Flyp: Test",
        "category": "Fly"
      },
      {
        "command": "fly.flypAdd",
        "title": "Flyp: Add Dependency",
        "category": "Fly"
      },
      {
        "command": "fly.flypLock",
        "title": "Flyp: Lock (Update fly.lock)",
        "category": "Fly"
      }
    ],
    "keybindings": [
      {
        "command": "fly.buildFile",
        "key": "ctrl+shift+b",
        "when": "editorLangId == fly"
      },
      {
        "command": "fly.buildFile",
        "key": "cmd+shift+b",
        "when": "editorLangId == fly"
      },
      {
        "command": "fly.runFile",
        "key": "ctrl+f5",
        "when": "editorLangId == fly"
      },
      {
        "command": "fly.runFile",
        "key": "cmd+f5",
        "when": "editorLangId == fly"
      },
      {
        "command": "fly.flypBuild",
        "key": "ctrl+shift+b",
        "when": "resourceFilename == fly.toml"
      },
      {
        "command": "fly.flypBuild",
        "key": "cmd+shift+b",
        "when": "resourceFilename == fly.toml"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "fly.runFile",
          "when": "resourceLangId == fly",
          "group": "navigation@1"
        },
        {
          "command": "fly.buildFile",
          "when": "resourceLangId == fly",
          "group": "navigation@2"
        },
        {
          "command": "fly.flypBuild",
          "when": "resourceFilename == fly.toml",
          "group": "navigation@1"
        },
        {
          "command": "fly.flypRun",
          "when": "resourceFilename == fly.toml",
          "group": "navigation@2"
        }
      ]
    },
    "problemMatchers": [
      {
        "name": "fly",
        "owner": "fly",
        "fileLocation": ["absolute"],
        "pattern": {
          "regexp": "^fly: (.+?):(\\d+):(\\d+):\\s+(error|warning|note|remark):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "fly",
        "required": ["task"],
        "properties": {
          "task": {
            "type": "string",
            "description": "The fly task to run (e.g. build)"
          }
        }
      }
    ],
    "snippets": [
      {
        "language": "fly",
        "path": "./snippets/fly.code-snippets"
      },
      {
        "language": "flyp-toml",
        "path": "./snippets/flyp-toml.code-snippets"
      }
    ],
    "configuration": {
      "title": "Fly",
      "properties": {
        "fly.compilerPath": {
          "type": "string",
          "default": "fly",
          "description": "Path to the Fly compiler executable. Used to run live diagnostics on save."
        },
        "fly.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run the Fly compiler on save and show errors and warnings as inline diagnostics."
        },
        "fly.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the fly-lsp binary. Leave empty to auto-discover next to fly.compilerPath."
        },
        "fly.enableLsp": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Fly Language Server for semantic features (hover on symbols, go-to-definition, find references)."
        },
        "fly.buildArgs": {
          "type": "string",
          "default": "",
          "description": "Extra arguments appended to the fly compiler when running 'Fly: Build File', e.g. \"-O2\" or \"-o bin/myapp\"."
        },
        "fly.flypPath": {
          "type": "string",
          "default": "",
          "description": "Path to the flyp binary. Leave empty to auto-discover next to fly.compilerPath."
        },
        "fly.flypBuildArgs": {
          "type": "string",
          "default": "",
          "description": "Extra arguments appended to flyp build, e.g. \"--release\" or \"--target mybin\"."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
